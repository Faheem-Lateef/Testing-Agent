OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# Auto-discovered when you paste a backend into this folder (e.g. ./ecommerce-backend)
# BACKEND_DIR=ecommerce-backend
# ROUTES_DIR=ecommerce-backend/src/routes
# BASE_APP_URL=http://localhost:3001
# GIT_REPO_ROOT=ecommerce-backend

AUTO_FIX_ON_FAILURE=true
MAX_PATCH_RETRIES=3

FIGMA_API_TOKEN=
FIGMA_FILE_KEY=
FIGMA_ROUTE_MAP={}
FIGMA_SOURCE_MAP={}

GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
GITHUB_BASE_BRANCH=main

WEBHOOK_PORT=4040
