# ─── AI provider (pick ONE key — provider is auto-detected) ───────────────────
# Universal (recommended):
# AI_API_KEY=

# Or provider-specific:
# OPENROUTER_API_KEY=sk-or-...
# GOOGLE_API_KEY=AIza...
# GEMINI_API_KEY=AIza...
# OPENAI_API_KEY=sk-proj-...
# ANTHROPIC_API_KEY=sk-ant-...
# GROQ_API_KEY=gsk_...

# Optional override: openrouter | google | openai | groq | anthropic
# AI_PROVIDER=openrouter

# Model (auto-default per provider if empty)
# AI_MODEL=
# OPENROUTER_MODEL=google/gemini-2.5-flash

# Auto-discovered when you paste a backend into this folder (e.g. ./ecommerce-backend)
# BACKEND_DIR=ecommerce-backend
# ROUTES_DIR=ecommerce-backend/src/routes
# BASE_APP_URL=http://localhost:3001
# FRONTEND_APP_URL=http://localhost:5173
# E2E_MOBILE_VIEWPORT=false
# GIT_REPO_ROOT=ecommerce-backend

AUTO_FIX_ON_FAILURE=true
MAX_PATCH_RETRIES=3

FIGMA_API_TOKEN=
FIGMA_FILE_KEY=
FIGMA_ROUTE_MAP={}
FIGMA_SOURCE_MAP={}

GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
GITHUB_BASE_BRANCH=main

WEBHOOK_PORT=4040
